// About
"about.appTitle" = "Dominate Your Mind";

// Awareness
"about.awareness.title" = "What is it?";
"about.awareness.text" = "Dominate Your Mind is a tool for managing what shapes your decisions.\n\nThe app presents selected images and messages you choose, creating a stable focus on your long-term goals.\n\nThis is not motivation.\nIt’s a system for intentional attention control.";

// Why it matters
"about.interruption.title" = "Why does it matter?";
"about.interruption.text" = "Behavior depends on frequently activated cognitive patterns.\n\nRepetition strengthens neural pathways and lowers their activation threshold.\nImages that regularly enter your field of attention gain priority in decision-making.\n\nIf you don’t choose what fills your attention, the environment will.\n\nDominate Your Mind gives you a tool to actively shape that cognitive context.";

// How it works
"about.howItWorks.title" = "How it works";
"about.howItWorks.text" = "You choose the images.\nThey repeatedly enter your field of attention.\nThis influences your next decision.\n\nThe app is a tool for controlling incoming stimuli.";

// Privacy
"about.privacy.title" = "Privacy";
"about.privacy.text" = "All data is stored locally on your device.\nThe app does not use servers and does not collect personal information.\nNo account required.\n\nYou stay in full control of your data.";

