/* About */
"about.appTitle" = "Dominate Your Mind";
"about.awareness.title" = "Ты — не твои мысли";
"about.awareness.text" = "Ум генерирует мысли автоматически.\nБольшинство из них возникает без намерения и выбора.\n\nМысли — это события, а не команды.\nТы не обязан им следовать.\n\nОсознанность начинается в тот момент,\nкогда ты замечаешь,\nчто делает твой ум.";
"about.interruption.title" = "Выход из автопилота";
"about.interruption.text" = "Большинство ментальных трудностей происходит на автопилоте.\n\nЭто приложение создаeт осознанную паузу —\nмежду импульсом и реакцией.\n\nИменно в этой паузе появляется выбор.";
"about.philosophy.title" = "Философия дизайна";
"about.philosophy.text" = "Простота здесь — намеренная.\n\nМозг глубже обрабатывает меньше информации.\nПоэтому приложение избегает лент, стриков и шума.\n\nКаждый элемент служит одной цели:\nснизить трение между осознанностью и действием.";
"about.howItWorks.title" = "Как это работает";
"about.howItWorks.text" = "Вы открываете приложение осознанно.\n\nВы видите одно сообщение.\nОдну идею.\nОдин момент ясности.\n\nБез трекинга.\nБез убеждения.\nБез бесконечной прокрутки.\n\nТолько осознанность — когда она нужна.";


